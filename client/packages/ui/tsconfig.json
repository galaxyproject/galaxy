{
    "extends": "@vue/tsconfig/tsconfig.json",
    "compilerOptions": {
        "target": "es2022",
        "module": "es2022",
        "moduleResolution": "Bundler",

        "verbatimModuleSyntax": true,

        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"]
        },

        "allowJs": true,
        "checkJs": false,
        "allowSyntheticDefaultImports": true,
        "noUncheckedIndexedAccess": true,

        "resolvePackageJsonExports": false
    },
    "vueCompilerOptions": {
        "target": 2.7
    },
    "include": ["./src/**/*.ts", "./src/**/*.vue"]
}
